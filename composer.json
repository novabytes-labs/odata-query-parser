{
    "name": "novabytes/odata-query-parser",
    "description": "Framework-agnostic OData 4 query string parser for PHP. Parses $filter, $select, $expand, $orderby, and more into AST objects.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "odata",
        "parser",
        "query",
        "filter",
        "ast",
        "rest",
        "api"
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "NovaBytes\\OData\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NovaBytes\\OData\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "lint": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "lint:fix": "vendor/bin/php-cs-fixer fix",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "archive": {
        "exclude": [
            "spec"
        ]
    }
}
